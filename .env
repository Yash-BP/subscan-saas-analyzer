# SubScan v2 — Analytics Engine Configuration
# Copy this file to .env and adjust values as needed.
# These values are loaded by analyze_waste.py via python-dotenv.

# Number of days without a login before a license is flagged as a zombie
INACTIVITY_THRESHOLD_DAYS=30

# Logins in the past 30 days at or below this number = At-Risk (not quite zombie)
LOW_USAGE_THRESHOLD=4

# Waste category labels written to the output CSV (change for your org's terminology)
WASTE_LABEL_ZOMBIE=Zero Usage in 30 Days (Zombie License)
WASTE_LABEL_TERMINATED=Terminated Employee (Wasted License)
WASTE_LABEL_AT_RISK=Low Usage (At-Risk License)
